}

@article{
  title = {A Roadmap for Effective and Sustainable Marine Protected Areas: Beyond Paper Parks},
  shorttitle = {A Roadmap for Effective and Sustainable Marine Protected Areas},
  author = {Trotman, Francesca G. V. and Berggren, Per},
  year = 2026,
  month = mar,
  journal = {Journal of Environmental Management},
  volume = {401},
  pages = {128956},
  issn = {0301-4797},
  doi = {10.1016/j.jenvman.2026.128956},
  urldate = {2026-03-10},
  abstract = {The marine environment faces increasing anthropogenic threats, highlighting the urgent need for proactive conservation and management to prevent irreversible climate change effects and biodiversity loss. Marine Protected Areas (MPAs) are a popular tool to tackle these threats. Amid increased pressures from international commitments and calls to protect larger areas of the oceans (30\% by 2030), questions have emerged regarding the effectiveness of MPAs. There is growing concern that MPAs become `paper parks' -- protected in principal but lacking effective regulation and enforcement. This study examines the drivers for effective MPAs and provides a roadmap for successful MPA implementation. We reviewed 202 publications from 2010 to 2024 assessing MPA effectiveness and used topic modelling to identify topics that create successful MPAs. Four key topic areas were identified as essential for MPA success: 1) Evaluation of Integrated Ecological and Socioeconomic Data, 2) Indigenous Engagement, Relationship Mapping and Governance, 3) Effective Location, Connectivity and Cover, and 4) Regulatory Management, Costs, Enforcement and Policy Framework. We use these topic areas to create a step-by-step roadmap for creation and implementation of effective MPAs. The results of the study and the created roadmap have global application for conservationists, policy makers, scientists and other stakeholders engaged in marine biodiversity and habitat conservation.},
  langid = {english},
  keywords = {Conservation,Effectiveness,Governance,Marine protected area},
  file = {D\:\\Zotero\\storage\\AYTK5L9N\\Trotman和Berggren - 2026 - A roadmap for effective and sustainable marine protected areas beyond paper parks.pdf;D\:\\Zotero\\storage\\T4CIKLBF\\S0301479726004160.html}
}

@article{
  title = {Evolutionary History and Seascape Genomics of Harbour Porpoises (Phocoena Phocoena) across Environmental Gradients in the North Atlantic and Adjacent Waters},
  author = {Celem{\'i}n, Enrique and Autenrieth, Marijke and Roos, Anna and Pawliczka, Iwona and Quintela, Mar{\'i}a and Lindstr{\o}m, Ulf and Benke, Harald and Siebert, Ursula and Lockyer, Christina and Berggren, Per and {\"O}zturk, A. Amaha and {\"O}zturk, Bayram and Lesage, V{\'e}ronique and Tiedemann, Ralph},
  year = 2025,
  journal = {Molecular Ecology Resources},
  volume = {25},
  number = {5},
  pages = {e13860},
  issn = {1755-0998},
  doi = {10.1111/1755-0998.13860},
  urldate = {2026-03-10},
  abstract = {The Harbour porpoise (Phocoena phocoena) is a highly mobile cetacean species primarily occurring in coastal and shelf waters across the Northern hemisphere. It inhabits heterogeneous seascapes broadly varying in salinity and temperature. Here, we produced 74 whole genomes at intermediate coverage to study Harbour porpoise's evolutionary history and investigate the role of local adaptation in the diversification into subspecies and populations. We identified 6 million high quality SNPs sampled at eight localities across the North Atlantic and adjacent waters, which we used for population structure, demographic and genotype--environment association analyses. Our results suggest a genetic differentiation between three subspecies (P.p. relicta, P.p. phocoena and P.p. meridionalis), and three distinct populations within P.p. phocoena: Atlantic, Belt Sea and Proper Baltic Sea. Effective population size and Tajima's D suggest population contraction in Black Sea and Iberian porpoises, but expansion in the P.p. phocoena populations. Phylogenetic trees indicate post-glacial colonization from a southern refugium. Genotype--environment association analysis identified salinity as major driver in genomic variation and we identified candidate genes putatively underlying adaptation to different salinity. Our study highlights the value of whole genome resequencing to unravel subtle population structure in highly mobile species, shows how strong environmental gradients and local adaptation may lead to population differentiation, and how neutral and adaptive markers can give different perspectives on population subdivision. The results have great conservation implications as we found inbreeding and low genetic diversity in the endangered Black Sea subspecies and identified the critically endangered Proper Baltic Sea porpoises as a separate population.},
  langid = {english},
  keywords = {conservation,genetic structure,genomics,harbour porpoise,local adaptation},
  file = {D\:\\Zotero\\storage\\CGJAZF9L\\Celemín 等 - 2025 - Evolutionary history and seascape genomics of harbour porpoises (phocoena phocoena) across environme.pdf;D\:\\Zotero\\storage\\KRZ97E4X\\1755-0998.html}
}

