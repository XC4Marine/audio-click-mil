@article{li2025MCADMM,
  title = {{{MCAD-MM}}: A Benchmark Dataset and Method for Multi-Channel Acoustic Detection of Marine Mammals},
  shorttitle = {Mcad-Mm},
  author = {Li, Nan and Shi, Zhensheng and Shao, Yuqi and Sun, Naizhe and Zheng, Bing and Zheng, Haiyong},
  year = 2025,
  month = jan,
  journal = {Intelligent Marine Technology and Systems},
  volume = {3},
  number = {1},
  pages = {1},
  issn = {2948-1953},
  doi = {10.1007/s44295-024-00051-2},
  urldate = {2026-01-15},
  abstract = {Marine mammals play an important role in maintaining the balance of marine ecosystems. A thorough understanding of their living habits, distribution, and environmental interaction is critical to formulating effective protection strategies. Traditional direct observation and sampling methods are limited in range, and it is challenging to cover the vast sea area because of the difficulties in operation and high cost. Passive acoustic monitoring (PAM) is an efficient and noninvasive technology to collect and analyze the sound signals of marine mammals via underwater deployment of hydrophones. However, the existing PAM studies are often limited by their focus on specific species or regions and need more universality. Moreover, the datasets and methods used need a unified benchmark, and the research results are difficult to integrate and share. This study proposes a novel approach based on deep learning (DL) to construct a common and systematic benchmark dataset and method for acoustic detection of marine mammals. The dataset is processed and analyzed via the combined use of the research data provided by the DCLDE Oahu dataset and the DL technology, covering acoustic signals and seawater ambient noises of various marine mammals, providing new data support and methodology guidance for research in related fields. The overall study involves a series of tasks: data acquisition, processing, labeling, methodology, experimental verification, and result analysis. We also use a Mamba-based state-space model for the detection of marine mammal vocalizations from the Mel-spectrogram representation of their acoustic signals. To the best of our knowledge, this is the first DL-based benchmark study on acoustic detection of marine mammals. This study not only provides a framework for the construction of a benchmark dataset and method based on a data-driven DL approach but also implements a unified process for data processing and quality assurance, laying a solid foundation for subsequent work and notably contributing to a broader understanding of marine biodiversity and conservation thereof.},
  langid = {english},
  keywords = {,/,Benchmark dataset,Benchmark method,Mamba model,Marine mammals,Multi-channel acoustic detection},
  annotation = {TLDR: This study provides a framework for the construction of a benchmark dataset and method based on a data-driven DL approach and implements a unified process for data processing and quality assurance, laying a solid foundation for subsequent work and notably contributing to a broader understanding of marine biodiversity and conservation thereof.},
  file = {D:\Zotero\storage\8GG4J6ZM\Li 等 - 2025 - MCAD-MM a benchmark dataset and method for multi-channel acoustic detection of marine mammals.pdf}
}

@article{liang2017Echolocation,
  title = {The Echolocation Transmission Beam of Free-Ranging Indo-Pacific Humpback Dolphins (Sousa Chinensis)},
  author = {Liang, Fang and Wu, Yuping and Wang, Kexiong and Pine, Matthew and Wang, Ding and Li, Songhai},
  year = 2017,
  month = aug,
  journal = {The Journal of the Acoustical Society of America},
  volume = {142},
  doi = {10.1121/1.4996499},
  abstract = {While the transmission beam of odontocetes has been described in a number of studies, the majority of them that have measured the transmission beam in two dimensions were focused on captive animals. Within the current study, a dedicated cross hydrophone array with nine elements was used to investigate the echolocation transmission beam of free-ranging Indo-Pacific humpback dolphins. A total of 265 on-axis clicks were analyzed, from which the apparent peak to peak source levels ranged between 168 to 207 dB (mean 184.5 dB \textpm{} 6.6 dB). The 3-dB beam width along the horizontal and vertical plane was 9.6{$^\circ$} and 7.4{$^\circ$}, respectively. Measured separately, the directivity index of the horizontal and vertical plane was 12.6 and 13.5 dB, respectively, and the overall directivity index (both planes combined) was 29.5 dB. The beam shape was slightly asymmetrical along the horizontal and vertical axis. Compared to other species, the characteristics of the transmitting beam of Indo-Pacific humpback dolphins were relatively close to the bottlenose dolphin (Tursiops truncatus), likely due to the similarity in the peak frequency and waveform of echolocation clicks and comparable body sizes of the two species.},
  langid = {english},
  keywords = {/,//},
  annotation = {TLDR: Compared to other species, the characteristics of the transmitting beam of Indo-Pacific humpback dolphins were relatively close to the bottlenose dolphin (Tursiops truncatus), likely due to the similarity in the peak frequency and waveform of echolocation clicks and comparable body sizes of the two species.},
  file = {D:\Zotero\storage\SKKHD2FK\Liang 等 - 2017 - The echolocation transmission beam of free-ranging indo-pacific humpback dolphins (sousa chinensis).pdf}
}

