@misc{noaanortheastfisheriessciencecenter2013DCLDE,
  title = {{{DCLDE}} 2013},
  author = {{NOAA Northeast Fisheries Science Center}},
  year = 2013,
  doi = {10.25921/zaea-1s39},
  urldate = {2026-01-06},
  abstract = {This dataset is a compilation of 1 week of acoustic data, collected in the Stellwagen Bank National Marine Sanctuary within the Western North Atlantic Ocean. The dataset was manually annotated for the presence of baleen whale calls in the western North Atlantic. It was originally part of the 2013 DCLDE (Detection, Classification, Localization, and Density Estimation) conference datasets, analyzed for North Atlantic right whale upcalls, and was recently re-analyzed for all baleen whale species and so all log files were from the same site (site 10, corresponds to channel 10 in multichannel data files) for the entire week of data. Each day of data was manually browsed in Raven 1.5, and anotated for all North Atlantic right whale (RIWH) upcalls, humpback whale (HUWH) song, sei whale (SEWH) downsweeps, fin whale (FIWH) 20-Hz pulses, minke whale (MIWH) pulse trains, and blue whale (BLWH) A/B/AB calls (for multichannel data, only one channel was analyzed and logged: channel 10). In the "Species" field, each single call is identified by the species abbreviations above; where "Species" = HUWH-MULTIPLE; multiple humpback whale vocalizations occur within that detection selection. In the "Detection\_Confidence" field, a definite upcall is marked as "Detected"; Possible or unknown detections ( i.e. a call could not be definitely attributed to the species marked), is marked as "Possibly\_Detected". Acoustic data and analysis provided by NOAA Northeast Fisheries Science Center's Passive Acoustics Branch; North Atlantic right whale upcalls annotated by Nicole Pegg and updated by Alexandra Carroll (Naval Undersea Warfare Center), calls for all other baleen whale species were annotated by Alexandra Carroll.},
  langid = {english},
  annotation = {Last Modified: 2026-01-06\\
titleTranslation: 北大西洋露脊鲸 upsweep \& gunshot 检测}
