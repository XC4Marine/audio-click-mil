  urldate = {2024-12-30},
  abstract = {Due to the complexity of the underwater environment, detecting underwater target signals, especially in low SNR conditions, remains challenging. In the context of marine mammal vocalization detection, several techniques have been used by human experts to distinguish and annotate vocalizations from background noise. However, manual analysis by human experts, where critical ratios (CRs) are calculated can be labor-intensive and subject to interpretation differences. These discrepancies may lead to false detections of vocalizations. To mitigate this limitation, this study proposes an ideal binary mask (IBM) method for separating marine mammal vocalizations from background noise. The effectiveness of this method was evaluated using a similarity coefficient and preserved signal ratio (PSR), which suggests that the IBM method holds potential for effectively distinguishing marine mammal vocalizations below the noise floor.},
  langid = {english},
  keywords = {/,//,acoustic source separation,Background noise,Deep learning,Distance measurement,Feature extraction,Floors,ideal binary mask,Manuals,Marine mammal vocalization,Oceans,Signal to noise ratio,Source separation,Underwater acoustics},
