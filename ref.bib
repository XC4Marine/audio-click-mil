@techreport{rideout2022Review,
  title = {A Review of Passive Acoustic Marine Mammal Call Detection Techniques},
  author = {Rideout, Brendan},
  year = 2022,
  month = may,
  institution = {{Defence Research and Development Canada}},
  abstract = {This Scientific Report presents a comparison of automated acoustic detection approaches found in the marine bioacoustics community (in particular, the marine mammal acoustic detection/classification/localization community). The motivation for this work comes from the priority within the Royal Canadian Navy (RCN) to improve the early detection of hostile torpedoes and the decades of experience within the marine bioacoustics community in detection of marine mammal vocalizations in a wide variety of underwater environments and sensor configurations. A survey of the recent literature on passive acoustic detection and classification of marine mammal calls was made, and a broad sampling of detection techniques (both established and experimental) identified. A common set of sample marine mammal calls were applied to the most promising and readily available of these detection approaches and the results compared. This comparison showed that while tonal detectors may not be the most appropriate for the detection of broadband signals, band-limited energy summation and information-entropy based detectors may be useful for the detection of underwater anthropogenic signals of interest, and that matched filtering may also prove a useful detection approach (particularly when the source waveform is known or reasonably consistent over time).},
  langid = {english},
  keywords = {/},
  annotation = {GSCC: 0000002 2025-09-11T15:36:40.653Z 0},
