@inproceedings{thomas2019Detecting,
  title = {Detecting Endangered Baleen Whales within Acoustic Recordings Using {{R-CNNs}}},
  booktitle = {In {{Proceedings}} of the {{AI}} for {{Social Good Workshop}} at {{NeurIPS}}},
