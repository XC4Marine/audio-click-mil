  journal = {维基百科，自由的百科全书},
  urldate = {2026-01-08},
  abstract = {海洋哺乳动物（又称海兽）泛指在海洋环境中栖息或因依赖海洋资源为生而需要在海洋中长时间活动的哺乳动物。此类哺乳动物包括完全水生的物种，比如鲸豚类（鲸类、海豚和鼠海豚）和海牛类（海牛和儒艮）；和需要部分时间上岸活动的半水生物种，包括鳍足类（海豹、海狗、海狮、海象）、北极熊和海獭。海洋哺乳动物并不是生物学中的分类单元或是系统分组，而是一个因为共享相似生态环境而被归属在一起的多系群，没有直接的共同起源，其唯一的共同特点是都依靠海洋环境生存，当中有部分的动物因为趋同演化会具有相似的解剖和生理特征。 海洋哺乳动物中，对水生生活形态的适应程度各有不同。像鲸目动物及海牛是完全水生的，只能在水中生存。海豹及海狮大部分的时间生活在水中，但是交配、养育后代都还是会到陆地上。海獭及北极熊比较是在陆地生活为主。其食物也有相当的差异，有些是吃浮游动物、其他的则吃鱼、鱿鱼，贝类，海草，也有些会吃其他的哺乳动物。海洋哺乳动物的数量比陆地上的哺乳动物要少很多，但在生态系中有许多不同的角色，包括其捕猎其他生物，维持生态系平衡在内，在维持海洋生态系中有重要的功用。但因为其重要的作用，而且有23\%的海洋哺乳动物物种目前已受到威胁，因此这种情形对海洋生态系有负面影响。 原住民一开始是因为需要食物及其他资源而猎鲸。后来许多海洋哺乳动物也成为商业猎捕的目标，造成已发现的物种（例如鲸鱼及海豹）数量大量的减少。商业猎捕也造成大海牛、海貂、日本海狮及加勒比僧海豹的绝种。在商业猎捕结束后，像灰鲸及北象海豹数量恢复不少，但是像北大西洋露脊鲸等物种，仍然是极危物种。此外，海洋哺乳动物也可能成为渔业的副渔获物，例如被固定网缠住，之后淹死或是挨饿。海上交通的日益普及，也增加了船只碰撞到海洋哺乳动物的机会。栖息地破坏威胁海洋哺乳动物，并且影响其寻找食物及捕猎的能力。例如噪音污染就影响回声定位的能力。而全球变暖的效应也让北极的环境恶化，因此令到生活在极地的海洋哺乳类生物走向减少和灭绝之路。},
  copyright = {Creative Commons Attribution-ShareAlike License},
  howpublished = {https://zh.wikipedia.org/w/index.php?title=\%E6\%B5\%B7\%E6\%B4\%8B\%E5\%93\%BA\%E4\%B9\%B3\%E5\%8B\%95\%E7\%89\%A9\&oldid=89871054},
  langid = {chinese},
  annotation = {Page Version ID: 89871054},
  file = {D:\Zotero\storage\IZC96BHX\index.html}
}

