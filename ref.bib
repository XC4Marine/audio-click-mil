@article{premus2025North,
  title = {North Atlantic Right Whale Detection Range Performance Quantification on a Bottom-Mounted Linear Hydrophone Array Using a Calibrated Acoustic Source},
  author = {Premus, Vincent E and Abbot, Philip A and Illich, Eric and Abbot, Ted A and Browning, John and Kmelnitsky, Vitaly},
  year = 2025,
