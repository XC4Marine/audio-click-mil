@article{sugarman2025Effects,
  title = {Effects of Network Selection and Acoustic Environment on Bounding-Box Object Detection of Delphinid Whistles Using a Deep Learning Tool},
  author = {Sugarman, Peter C. and Ferguson, Elizabeth L. and Alongi, Gabriela C. and Schallert, Jennifer Pettis and Lyn, Heidi},
  year = 2025,
  month = jun,
  journal = {The Journal of the Acoustical Society of America},
