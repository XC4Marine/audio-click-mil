@article{liu2024Species,
  title = {Species Diversity and Critical Habitats of Offshore and Deep-Diving Cetaceans in the South {{China}} Sea},
  author = {Liu, Mingming and Lin, Wenzhi and Lin, Mingli and Dong, Lijun and Liu, Binshuai and Chen, Shenglan and Ouyang, Mingyue and Zhang, Peijun and Yang, Zixin and Kang, Hui and Li, Songhai},
