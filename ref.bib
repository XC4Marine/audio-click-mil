  author = {Livina, Valerie N. and Brouwer, Albert and Harris, Peter and Wang, Lian and Sotirakopoulos, Kostas and Robinson, Stephen},
  year = 2018,
  month = feb,
  journal = {Nonlinear Processes in Geophysics},
  volume = {25},
