@article{nguyenhongduc2026Geographical,
  title = {Geographical and Seasonal Distribution of Australian Pygmy Right Whales (Caperea Marginata) Based on Passive Acoustics},
  author = {Nguyen Hong Duc, Paul and Lefebvre, Gr{\'e}goire and Quimbert, Malo and Gavrilov, Alexander N. and McCauley, Robert D. and Jenner, Curt and Jenner, Micheline N. and Davenport, Andrew and Browne, Ciara E. and Ward, Rhianne and Charlton, Claire and Erbe, Christine},
  year = 2026,
  journal = {Marine Mammal Science},
  volume = {42},
  number = {2},
  pages = {e70132},
  issn = {1748-7692},
  doi = {10.1111/mms.70132},
  urldate = {2026-02-08},
  abstract = {The pygmy right whale (Caperea marginata) is one of the least studied mysticete species. To shed light on its geographic and seasonal distribution, we compiled archival acoustic recordings from 26 sites across southern Australia and developed a deep-learning detector for pygmy right whale ``doublet'' vocalizations. Seasonal patterns differed markedly between regions: On the southwestern shelf, detections consistently peaked between July and November (with an anomalous early season in March--June 2012), whereas southeastern waters exhibited more dispersed year-round call presence, with pronounced peaks in July--October 2012, March, May--June, August, November--December 2015, June--November 2016, and February 2017. Co-occurrence analysis of doublet and ``spot'' calls revealed synchronized presence/absence, supporting the hypothesis that both call types originate from the same species. Our findings underscore region-specific habitat use and seasonal migration of pygmy right whales and highlight the value of automated acoustic techniques combined with ecological context for monitoring cryptic cetaceans in data-limited environments.},
  langid = {english},
  keywords = {/,//,Australia,bioacoustics,Caperea marginata,deep learning,pygmy right whale,spot call},
  annotation = {TLDR: Co-occurrence analysis of doublet and ``spot'' calls revealed synchronized presence/absence, supporting the hypothesis that both call types originate from the same species.},
  file = {D\:\\Zotero\\storage\\LX5DGMPM\\Nguyen Hong Duc 等 - 2026 - Geographical and seasonal distribution of australian pygmy right whales (caperea marginata) based on.pdf;D\:\\Zotero\\storage\\A9YJC6DT\\mms.html}
}

