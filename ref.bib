@misc{
  title = {The Effects of Signal-to-Noise Ratio on Generative Adversarial Networks Applied to Marine Bioacoustic Data},
  author = {Atkinson, Georgia and Wright, Nick and McGough, A. Stephen and Berggren, Per},
  year = 2023,
  month = dec,
  number = {arXiv:2312.14806},
