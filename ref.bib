@article{miller2023Deep,
  title = {Deep Learning Algorithm Outperforms Experienced Human Observer at Detection of Blue Whale {{D-calls}}: A Double-Observer Analysis},
  shorttitle = {Deep Learning Algorithm Outperforms Experienced Human Observer at Detection of Blue Whale {{D-calls}}},
  author = {Miller, Brian S. and Madhusudhana, Shyam and Aulich, Meghan G. and Kelly, Nat},
  year = 2023,
