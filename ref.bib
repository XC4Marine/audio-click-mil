  keywords = {/,Acoustics,Bioacoustics,Databases,deep learning,Fourier transforms,Indexes,marine mammals vocalization,Monitoring,Scattering,signal processing,Spectrogram,Time-frequency analysis,wavelet scattering transform,Wavelet transforms,Whales},
