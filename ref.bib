  issn = {2837-116X},
  doi = {10.1109/ICSPCC66825.2025.11194372},
  urldate = {2026-02-02},
  abstract = {Denoising dolphin whistles lays the groundwork for subsequent feature extraction and for studying how dolphins adaptively modify their whistles in response to noise interference. To address the challenges of inaccurate noise estimation and residual noise in wavelet thresholding under non-stationary underwater noise, this study proposes an improved Stein's Unbiased Risk Estimator (SURE) thresholding method. The proposed method innovatively combines impulse noise suppression with a wavelet subband noise estimation strategy based on the integral area of the zero-crossing rate (ZCR). Results demonstrate that the improved SURE method outperforms other threshold denoising techniques. Furthermore, within the same SURE framework, the subband-based noise estimation in the improved method outperforms approaches that rely on fixed noise intervals for threshold selection, providing a more adaptive and accurate preprocessing strategy for dolphin whistle analysis and future research.},
  langid = {english},
  keywords = {//,Accuracy,bioacoustics,dolphin whistle signal,Dolphins,Estimation,Feature extraction,Interference,Noise,Noise reduction,Signal detection,Simulation,underwater noise estimation,Wavelet coefficients,wavelet denoising},
