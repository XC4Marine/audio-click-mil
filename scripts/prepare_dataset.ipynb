# scripts/prepare_dataset.py
import os
import random
import pandas as pd
import numpy as np
from pathlib import Path
from typing import List, Dict, Tuple

# ----------------------- 配置 -----------------------
ROOT = Path(r"D:\Project_Github\audio_click_mil")
AUDIO_DIR = ROOT / "data" / "original_audio"
CSV_DIR = ROOT / "data"

OUTPUT_ROOT = ROOT / "processed_data"
OUTPUT_ROOT.mkdir(exist_ok=True, parents=True)

TEST_FILES = set(range(1,
9))           # 1~8 作为独立测试集
EXCLUDE_FILES = {
    12
}                     # 无pulse信号的文件

# 固定随机种子，保证可复现
RANDOM_SEED = 42
random.seed(RANDOM_SEED)
np.random.seed(RANDOM_SEED)

# ----------------------- 工具函数 -----------------------
def get_audio_files() -> List[Path
]:
    return sorted([f for f in AUDIO_DIR.glob("*.wav")
],
                  key=lambda x: int(x.stem[
    -2:
]))   # 按Ori_file_num排序


def load_train_csvs() -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame
]:
    click = pd.read_csv(CSV_DIR / "ClickTrains.csv")
    burst = pd.read_csv(CSV_DIR / "BurstPulseTrains.csv")
    buzz  = pd.read_csv(CSV_DIR / "BuzzTrains.csv")
    # 统一列名（部分文件可能列名有差异）
    for df in [click, burst, buzz
]:
        df.columns = df.columns.str.strip()
    return click, burst, buzz


def parse_file_num(filename: str) -> int: """从文件名提取 Ori_file_num，例如 xxx_01.wav → 1"""
    stem = Path(filename).stem
    return int(stem[
    -2:
])


# ----------------------- 1. 划分数据集 -----------------------
def split_dataset():
    all_files = get_audio_files()
    file_nums = {parse_file_num(f): f for f in all_files
}

    # 测试集：1~8
    test_files = [file_nums[i
    ] for i in range(1,
    9) if i in file_nums
]

    # 训练/验证候选：9~35 排除12
    trainval_nums = [i for i in range(9,
    36) if i not in EXCLUDE_FILES and i in file_nums
]
    trainval_files = [file_nums[i
    ] for i in trainval_nums
]

    print(f"测试集文件数: {len(test_files)} (Ori 1-8)")
    print(f"训练/验证文件数: {len(trainval_files)} (排除12后)")

    # 5折划分
    random.shuffle(trainval_files)  # 打乱
    folds = np.array_split(trainval_files,
5)

    split_info = {
    "test": [str(p) for p in test_files
    ],
    "folds": []
}

    for i, fold_files in enumerate(folds,
1):
        # 每折最后一个文件作为验证集
        val_file = fold_files[
    -1
]
        train_files = fold_files[
    : -1
]

        split_info[
    "folds"
].append({
    "fold": i,
    "train": [str(p) for p in train_files
    ],
    "val": str(val_file)
})

    # 保存划分结果
    import json
    with open(OUTPUT_ROOT / "data_split.json",
"w", encoding="utf8") as f:
        json.dump(split_info, f, ensure_ascii=False, indent=2)

    print("划分完成，已保存到 processed_data/data_split.json")
    return split_info


